# =============================================================================
# MOLYNK BACKEND — ENVIRONMENT VARIABLES TEMPLATE
# Copy this to .env and fill in your values
# =============================================================================

PORT=3000
NODE_ENV=development

# DEV: ngrok URL | PROD: https://api.molynk.co.za
TWILIO_WEBHOOK_BASE_URL=https://your-ngrok-url.ngrok-free.app

# DEV: http://localhost:3001 | PROD: https://app.molynk.co.za
WEB_APP_URL=http://localhost:3001

# Firebase (Project Settings → Service Accounts → Generate new private key)
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=""

# Twilio — DEV: friend's account | PROD: your own master account
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=

# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=

# Paystack — DEV: sk_test_... | PROD: sk_live_...
PAYSTACK_SECRET_KEY=
PAYSTACK_PUBLIC_KEY=
PAYSTACK_PLAN_STARTER=
PAYSTACK_PLAN_BUSINESS=
PAYSTACK_PLAN_PRO=
PAYSTACK_WEBHOOK_SECRET=
